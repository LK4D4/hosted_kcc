# Copy to .env and replace values for your host.

TZ=Etc/UTC
PUID=1000
PGID=1000
DOCKER_NETWORK_MODE=bridge
# Synology users may prefer:
# DOCKER_NETWORK_MODE=synobridge

# Generic hosted-kcc deployment.
HOSTED_KCC_DATA_DIR=/path/to/hosted-kcc/data
HOSTED_KCC_INPUT_DIR=/path/to/downloads
HOSTED_KCC_OUTPUT_DIR=/path/to/converted

# Suwayomi side-by-side deployment.
SUWAYOMI_AUTH_USERNAME=change-me
SUWAYOMI_AUTH_PASSWORD=change-me
SUWAYOMI_PORT=4567
SUWAYOMI_DOWNLOADS_DIR=/path/to/suwayomi/downloads
SUWAYOMI_DATA_DIR=/path/to/suwayomi/data

# For Suwayomi Local Source, these usually point to:
# HOSTED_KCC_INPUT_DIR=<Suwayomi downloads>/mangas
# HOSTED_KCC_OUTPUT_DIR=<Suwayomi data>/local
